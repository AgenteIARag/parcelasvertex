    {
      "parameters": {
        "jsCode": "// ─── Parseia resposta do Claude e recupera dados do processo ───────\nconst prev = $('Tem Novidade?').first().json;\nconst r    = items[0].json;\n\nlet text = '';\nif (Array.isArray(r.content)) {\n  text = r.content.find(b => b.type === 'text')?.text || '';\n} else {\n  text = String(r.content || '');\n}\n\nconst clean = text.replace(/```json|```/g, '').trim();\n\nlet p = {};\ntry {\n  p = JSON.parse(clean);\n} catch(e) {\n  p = { resumo_cliente: text || 'Não foi possível gerar o resumo.', status_interno: 'outro', urgencia: 'baixa', acao_necessaria: 'nenhuma' };\n}\n\nreturn [{ json: {\n  ...prev,\n  resumo_claude:    p.resumo_cliente  || '',\n  status_interno:   p.status_interno  || 'outro',\n  urgencia:         p.urgencia        || 'baixa',\n  acao_necessaria:  p.acao_necessaria || 'nenhuma'\n}}];"
      },
