    {
      "parameters": {
        "jsCode": "// ─── Identificação do sistema pelo número CNJ ─────────────────────\n// Formato: NNNNNNN-DD.AAAA.J.TT.OOOO (20 dígitos sem formatação)\nconst item = items[0].json;\nconst processo = (item.numero_processo || '').trim();\nconst d = processo.replace(/\\D/g, '');\n\nif (d.length !== 20) {\n  throw new Error('Número CNJ inválido: ' + processo + ' (' + d.length + ' dígitos, esperado 20)');\n}\n\nconst seg = d.charAt(13);        // J = segmento de justiça\nconst tCod = d.substring(14,16); // TT = código do tribunal\n\nconst tjMap = {\n  '01':'TJAC','02':'TJAL','03':'TJAM','04':'TJAP','05':'TJBA',\n  '06':'TJCE','07':'TJDF','08':'TJES','09':'TJGO','10':'TJMA',\n  '11':'TJMT','12':'TJMS','13':'TJMG','14':'TJPA','15':'TJPB',\n  '16':'TJPR','17':'TJPE','18':'TJPI','19':'TJRJ','20':'TJRN',\n  '21':'TJRS','22':'TJRO','23':'TJRR','24':'TJSC','25':'TJSE',\n  '26':'TJSP','27':'TJTO'\n};\nconst esajHosts = {\n  'TJSP':'esaj.tjsp.jus.br','TJBA':'esaj.tjba.jus.br','TJSC':'esaj.tjsc.jus.br',\n  'TJCE':'esaj.tjce.jus.br','TJMG':'esaj.tjmg.jus.br','TJMS':'esaj.tjms.jus.br',\n  'TJPR':'esaj.tjpr.jus.br','TJRJ':'esaj.tjrj.jus.br','TJRS':'esaj.tjrs.jus.br'\n};\n\nlet sistema = 'pje', tribunalNome = 'Tribunal', esajHost = '';\n\nif (seg === '8') {\n  sistema = 'esaj';\n  tribunalNome = tjMap[tCod] || 'TJ' + tCod;\n  esajHost = esajHosts[tribunalNome] || 'esaj.' + tribunalNome.toLowerCase() + '.jus.br';\n} else if (seg === '4') {\n  if (tCod === '01')      { sistema = 'eproc'; tribunalNome = 'TRF1'; }\n  else if (tCod === '04') { sistema = 'eproc'; tribunalNome = 'TRF4'; }\n  else                    { sistema = 'pje';   tribunalNome = 'TRF' + parseInt(tCod); }\n} else if (seg === '5') {\n  sistema = 'pje';\n  tribunalNome = 'TRT' + parseInt(tCod);\n} else {\n  sistema = 'pje';\n  tribunalNome = 'Tribunal Seg.' + seg + '-' + tCod;\n}\n\nreturn [{ json: {\n  ...item,\n  segmento: seg,\n  tribunal_codigo: tCod,\n  tribunal_nome: tribunalNome,\n  esaj_host: esajHost,\n  sistema,\n  numero_processo_limpo: d\n}}];"
      },
