      "id": "63bbe699-b033-42b1-a8ed-7d4df9312551",
      "name": "Consultar eproc",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        480,
        384
      ]
    },
    {
      "parameters": {
        "jsCode": "// ─── Extrai dados da resposta do tribunal ──────────────────────────\n// Recupera dados originais do processo (perdidos após HTTP Request)\nconst proc = $('Identificar Sistema CNJ').first().json;\nconst resp = items[0].json;\nconst html = resp.data || '';\nconst sistema = proc.sistema;\n\nlet ultima_mov = 'Não identificado automaticamente — verificar manualmente';\nlet data_mov = '', autor = '', reu = '', proxima_audiencia = null;\n\nif (sistema === 'esaj') {\n  // ── e-SAJ (HTML) ──────────────────────────────────────────────────\n  const movM = html.match(/class[^>]*descricao[^>]*>\\s*([^<]{10,120})/i)\n             || html.match(/Andamento[^<]*<\\/th>([\\s\\S]{0,200}?)<td[^>]*>([^<]{10,})/i);\n  if (movM) ultima_mov = (movM[2] || movM[1]).trim();\n\n  const dateM = html.match(/(\\d{2}\\/\\d{2}\\/\\d{4})/);\n  if (dateM) data_mov = dateM[1];\n\n  const autorM = html.match(/Requerente[^:]*:\\s*<[^>]*>([^<]{5,60})/i)\n               || html.match(/Autor[^:]*:\\s*<[^>]*>([^<]{5,60})/i);\n  const reuM   = html.match(/Requerido[^:]*:\\s*<[^>]*>([^<]{5,60})/i)\n               || html.match(/R[eé]u[^:]*:\\s*<[^>]*>([^<]{5,60})/i);\n  if (autorM) autor = autorM[1].trim();\n  if (reuM)   reu   = reuM[1].trim();\n\n} else if (sistema === 'pje') {\n  // ── PJe (JSON ou HTML) ────────────────────────────────────────────\n  try {\n    const j = typeof resp === 'object' && resp.content ? resp : JSON.parse(html);\n    const m = j?.movimento?.[0] || j?.movimentos?.[0] || j?.data?.[0];\n    if (m) {\n      ultima_mov = m.descricao || m.nome || m.complementoTabelado || 'Ver PJe';\n      data_mov   = (m.dataHora || m.dtMovimento || '').substring(0,10);\n    }\n    autor = j?.polo?.ativo?.[0]?.nome || '';\n    reu   = j?.polo?.passivo?.[0]?.nome || '';\n  } catch(e) {\n    const m = html.match(/class[^>]*descricao[^>]*>([^<]{10,120})/i);\n    if (m) ultima_mov = m[1].trim();\n  }\n\n} else if (sistema === 'eproc') {\n  // ── eproc (HTML) ──────────────────────────────────────────────────\n  const m = html.match(/class[^>]*evento[^>]*>[\\s\\S]*?<td[^>]*>([^<]{10,120})/i);\n  if (m) ultima_mov = m[1].trim();\n  const d = html.match(/(\\d{2}\\/\\d{2}\\/\\d{4})/);\n  if (d) data_mov = d[1];\n}\n\nreturn [{ json: {\n  ...proc,\n  ultima_movimentacao: ultima_mov,\n  data_movimentacao: data_mov,\n  status: 'Em andamento',\n  autor, reu, proxima_audiencia\n}}];"
      },
